NODE_ENV=production
HOST=0.0.0.0
PORT=8787

# Gere um segredo aleatorio com pelo menos 32 caracteres e use o mesmo valor
# em YTDLP_SERVICE_TOKEN no Supabase. Nunca publique o valor real.
YTDLP_SERVICE_TOKEN=troque-por-um-segredo-com-32-caracteres

# Origem HTTPS publica do container, sem caminho ou barra final.
PUBLIC_BASE_URL=https://worker.example.com

YT_DLP_BINARY=yt-dlp
TMP_ROOT=
MAX_VIDEO_MIB=300
MAX_CONCURRENT_JOBS=2
DOWNLOAD_TIMEOUT_MS=900000
SIGNED_URL_TTL_MS=900000
REQUEST_BODY_MAX_BYTES=16384
